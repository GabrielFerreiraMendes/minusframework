-  .Onde(OuCriterios([
-    Criterio('NOME').Igual('Alpha'),
-    Criterio('NOME').Igual('Gamma')
-  ]))
-  .ParaLista;
-
-// AND + OR combinados
-LLista := LRepo.Consulta
-  .Onde(Criterio('ATIVO').Igual(True))
-  .Onde(OuCriterios([
-    Criterio('TIPO').Igual('A'),
-    Criterio('TIPO').Igual('B')
-  ]))
-  .ParaLista;
-
-// NOT
-LLista := LRepo.Consulta
-  .Onde(Nao(Criterio('STATUS').Igual('CANCELADO')))
-  .ParaLista;
-```
-
-### 6.3 Subconsultas
