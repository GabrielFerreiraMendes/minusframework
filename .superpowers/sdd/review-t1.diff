-  public
-    function ProximoIntervalo(const ATentativa: Integer): Integer; override;
-    // 1├é┬¬: 1s, 2├é┬¬: 2s, 3├é┬¬: 4s, 4├é┬¬: 8s... at├â┬® FMaxMs
-  end;
-
-  TFixedBackoff = class(TBackoffPolicy)
