-## Quick Start
-
-### 1. Definir Entidade
-
-```pascal
-type
-  [Tabela('PRODUTO')]
-  [Cache(300, 'produtos')]
-  TProduto = class
-  private
-    [ChavePrimaria]
-    [Coluna('ID')]
-    FId: Integer;
-    [Coluna('NOME')]
-    [NotNull]
-    FNome: string;
-    [Coluna('PRECO_VENDA')]
-    FPrecoVenda: Currency;
