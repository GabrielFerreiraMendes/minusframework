-mysql://localhost:3306/mydb?user=root&password=123
-mssql://localhost:1433/mydb?user=sa&password=123
-oracle://localhost:1521/XEPDB1?user=system&password=123
-mariadb://localhost:3307/mydb?user=root&password=123
-```
